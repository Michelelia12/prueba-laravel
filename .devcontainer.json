{
    "name": "prueba-laravel-devcontainer",
    "dockerComposeFile": [
        "docker/docker-compose-dev.yml"
    ],
    "service": "devcontainer",
    "mounts": [
        "source=/home/${localEnv:USER}/.ssh,target=/home/ubuntu/.ssh,readonly,type=bind,consistency=cached",
        "source=${localWorkspaceFolder},target=/home/ubuntu/workspace,type=bind,consistency=cached"
    ],
    "remoteUser": "ubuntu",
    "updateRemoteUserUID": false,
    "overrideCommand": false,
    "workspaceFolder": "/home/ubuntu/workspace",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "laravel.vscode-laravel",
                "bradlc.vscode-tailwindcss",
                "tomoki1207.pdf"
            ]
        }
    }
}